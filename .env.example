# ── Core runtime (required) ───────────────────────────────
# Supabase project URL + keys
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public app base URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional direct Postgres URL (used by some migration/utility scripts)
DATABASE_URL=

# ── AI Providers (optional) ───────────────────────────────
# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_EMBEDDING_DEPLOYMENT=

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PLATFORM_WEBHOOK_SECRET=

# ── Sentry (error monitoring) ─────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Platform SMTP (email) ────────────────────────────────
PLATFORM_SMTP_HOST=
PLATFORM_SMTP_PORT=587
PLATFORM_SMTP_USER=
PLATFORM_SMTP_PASSWORD=
PLATFORM_SMTP_FROM_EMAIL=
PLATFORM_SMTP_FROM_NAME=Open Commerce

# ── WhatsApp (Baileys) ───────────────────────────────────
BAILEYS_SERVER_URL=
BAILEYS_API_SECRET=

# ── Internal secrets ─────────────────────────────────────
INTERNAL_API_SECRET=
EMAIL_INTERNAL_SECRET=
MIGRATION_SECRET=
CRON_SECRET=
MCP_API_KEY=
MCP_CLIENT_SECRET=
MCP_JWT_SECRET=

# ── Optional ─────────────────────────────────────────────
LOG_LEVEL=info
NEXT_PUBLIC_GSC_VERIFICATION_ID=
